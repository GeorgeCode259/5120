# Flask Configuration
FLASK_APP=app
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-me

# Neon Database Connection (Pooled - Recommended for Serverless/Vercel)
# Format: postgres://<user>:<password>@<host-pooler>/<dbname>?sslmode=require
DATABASE_URL=postgres://user:password@ep-pooler.region.neon.tech/neondb?sslmode=require

# Neon Database Connection (Direct - Required for Migrations)
# Format: postgres://<user>:<password>@<host-direct>/<dbname>?sslmode=require
DIRECT_URL=postgres://user:password@ep-direct.region.neon.tech/neondb?sslmode=require

# External APIs
OPENWEATHER_API_KEY=your_openweather_api_key
